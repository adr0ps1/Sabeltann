<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sabeltann.ViewModels"
        xmlns:ctrl="using:Sabeltann.Controls"
        xmlns:views="using:Sabeltann.Views"
        x:Name="ThisWindow"
        xmlns:c="using:Sabeltann.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Sabeltann.MainWindow"
        Title="Sabeltann - IPTV Player"
        Background="#1e1e2e">

    <Window.Resources>
        <c:BoolToColorConverter x:Key="StarColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.TransportBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="2"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#ffffff15"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="#ffffff25"/>
            </Style>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid x:Name="MainGrid" RowDefinitions="44,Auto,*,28">

        <Grid x:Name="TitleBar" Grid.Row="0" ColumnDefinitions="Auto,Auto,*" Background="#181825">
            <Grid Grid.Column="0" ColumnDefinitions="Auto,Auto" Background="#181825">
            <Border Padding="14,0,12,0" Background="#181825">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="6" Background="#cba6f7">
                        <TextBlock Text="☠" Foreground="#1e1e2e" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SABELTANN" Foreground="#cdd6f4" FontSize="12"
                               FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="4,0,0,0">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                         Fill="{Binding IsConnected, Converter={x:Static vm:MainViewModel.ConnDot}}"/>
                <TextBlock Text="{Binding ConnectionLabel}" Foreground="#6c7086" FontSize="11"/>
            </StackPanel>
            </Grid>
            <Menu x:Name="MainMenu" Grid.Column="1" Background="#181825" Foreground="#cdd6f4"
                  FontSize="13">
                <MenuItem Header="_File">
                    <MenuItem Header="Load M3U URL..." Click="OnLoadM3UUrl"/>
                    <MenuItem Header="Load M3U File..." Click="OnLoadM3UFile"/>
                    <Separator/>
                    <MenuItem Header="Xtream Login..." Click="OnXtreamLogin"/>
                    <Separator/>
                    <MenuItem Header="_Settings..." Click="OnSettings"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Click="OnExit"/>
                </MenuItem>
            </Menu>
        </Grid>

        <Border x:Name="CategoryBar" Grid.Row="1" Padding="10,7" Background="#313244"
                IsVisible="{Binding IsCategoryBarVisible}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Width="28" Height="28" Padding="0" Margin="0,0,8,0"
                        Command="{Binding GoBackToPickerCommand}"
                        ToolTip.Tip="Back to menu">
                    <TextBlock Text="←" Foreground="#a6adc8" FontSize="14"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Category" VerticalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#a6adc8" LetterSpacing="1"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberBinding="{Binding Name}"
                              MinWidth="150" FontSize="12"/>
                </StackPanel>
                <ToggleButton Grid.Column="2" IsChecked="{Binding ShowFavoritesOnly}"
                              Background="Transparent" BorderThickness="0"
                              Margin="6,0,0,0" Padding="4,0"
                              VerticalAlignment="Center"
                              IsVisible="{Binding IsLiveTv}">
                    <TextBlock Text="★" Foreground="#f9e2af" FontSize="13"/>
                </ToggleButton>
                <TextBox Grid.Column="3" Text="{Binding SearchText}"
                         PlaceholderText="Search channels..."
                         Background="#1e1e2e" Foreground="#cdd6f4"
                         BorderThickness="1" BorderBrush="#45475a"
                         FontSize="12" Padding="6,4"
                         Margin="8,0" VerticalAlignment="Center"/>
                <ToggleButton Grid.Column="4" IsChecked="{Binding ShowDebugOverlay}"
                              Background="Transparent" BorderThickness="0"
                              Margin="4,0" Padding="6,2"
                              VerticalAlignment="Center">
                    <TextBlock Text="DEBUG" Foreground="#f38ba8" FontSize="9" FontWeight="Bold"
                               LetterSpacing="1"/>
                </ToggleButton>
                <Border Grid.Column="5" CornerRadius="10" Background="#313244" 
                        Padding="8,2" Margin="6,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ChannelCount, StringFormat='{}{0} channels'}"
                               Foreground="#a6adc8" FontSize="11"/>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="2" ColumnDefinitions="*">

            <Grid Grid.Column="0">
                <!-- Channel grid for Live TV -->
                <ScrollViewer IsVisible="{Binding ShowChannelGrid}" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel Margin="12,8">
                        <ItemsControl ItemsSource="{Binding FilteredChannels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0" Margin="4,4" Background="#181825"
                                            CornerRadius="10" BorderThickness="1" BorderBrush="#313244"
                                            Width="200" Height="140">
                                        <Grid RowDefinitions="*,Auto">
                                            <Button Grid.Row="0" Background="Transparent" BorderThickness="0"
                                                    CornerRadius="10,10,0,0" Padding="0"
                                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                    Command="{Binding $parent[Window].DataContext.SelectChannelCommand}"
                                                    CommandParameter="{Binding .}">
                                                <Border Background="#313244" CornerRadius="10,10,0,0">
                                                    <Grid>
                                                        <Image Source="{Binding LogoSrc}" Stretch="UniformToFill"
                                                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                                        <Border Width="40" Height="40" CornerRadius="10"
                                                                Background="{Binding Name, Converter={x:Static vm:MainViewModel.HashColor}}"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                IsVisible="{Binding LogoSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}">
                                                            <TextBlock Text="{Binding Name, Converter={x:Static vm:MainViewModel.FirstChar}}"
                                                                       Foreground="#cdd6f4" FontSize="16" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Button Background="Transparent" BorderThickness="0"
                                                                Width="28" Height="28" Padding="0"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                Command="{Binding $parent[Window].DataContext.ToggleFavoriteCommand}"
                                                                CommandParameter="{Binding .}">
                                                            <TextBlock Text="★" FontSize="14"
                                                                       Foreground="{Binding IsFavorite, Converter={StaticResource StarColorConverter}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                            <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="#cdd6f4" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" Margin="8,4"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </ScrollViewer>

                <Border Background="#11111b" IsVisible="{Binding ShowVideo}">
                    <ctrl:VideoView x:Name="VideoView"/>
                </Border>

                <Button Background="#44000000" BorderThickness="0" CornerRadius="8"
                        Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="8" Padding="0" IsVisible="{Binding ShowVideo}"
                        Command="{Binding StopPlaybackCommand}" ZIndex="10">
                    <TextBlock Text="✕" Foreground="#f38ba8" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <views:ConnectionPage x:Name="ConnectionPage" IsVisible="{Binding IsWelcome}"/>

                <views:ContentPicker x:Name="ContentPicker" IsVisible="{Binding IsPicker}"/>
                <Border IsVisible="{Binding IsMovies}" Background="#11111b">
                    <views:VodBrowser DataContext="{Binding VodBrowser}"/>
                </Border>
                <Border IsVisible="{Binding IsSeries}" Background="#11111b">
                    <views:SeriesBrowser DataContext="{Binding SeriesBrowser}"/>
                </Border>

                <Border IsVisible="{Binding ShowConnectionOverlay}"
                        Background="#cc11111b" CornerRadius="12" Padding="28"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="280">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionState}" Foreground="#cdd6f4"
                                   FontSize="14" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <ProgressBar Value="{Binding ConnectionProgress}" Maximum="100"
                                     MinWidth="200" Height="4" Foreground="#cba6f7"
                                     Background="#313244" IsIndeterminate="False"
                                     HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionProgress, StringFormat='{}{0}%'}"
                                   Foreground="#6c7086" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Panel x:Name="OverlayPanel" Background="Transparent"
                       IsVisible="{Binding IsPlaying}" Opacity="0"
                       PointerEntered="OnOverlayEntered"
                       PointerExited="OnOverlayExited">
                    <Border Background="#cc000000" CornerRadius="16" Padding="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <Button Width="42" Height="42" FontSize="18"
                                    Command="{Binding RewindCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="21">
                                <TextBlock Text="⏪" Foreground="#cdd6f4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Width="52" Height="52" FontSize="24"
                                    Command="{Binding TogglePlayPauseCommand}"
                                    Background="#cba6f7" BorderThickness="0" CornerRadius="26">
                                <TextBlock Text="{Binding PlayPauseSymbol}" Foreground="#1e1e2e"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button Width="42" Height="42" FontSize="18"
                                    Command="{Binding ForwardCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="21">
                                <TextBlock Text="⏩" Foreground="#cdd6f4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Panel>
            </Grid>
        </Grid>

        <Popup x:Name="TransportPopup" IsLightDismissEnabled="False"
               OverlayDismissEventPassThrough="True" MinWidth="1200"
               HorizontalOffset="0" VerticalOffset="-60">
            <Border Padding="8,5" Background="#cc000000" CornerRadius="8" MinWidth="600">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">

                    <Button Grid.Column="0" Classes="TransportBtn"
                            Command="{Binding TogglePlayPauseCommand}">
                        <TextBlock Text="{Binding PlayPauseSymbol}" Foreground="#cdd6f4" FontSize="12"/>
                    </Button>

                    <Button Grid.Column="1" Classes="TransportBtn"
                            Command="{Binding StopCommand}">
                        <TextBlock Text="⏹" Foreground="#f38ba8" FontSize="11"/>
                    </Button>

                    <Button Grid.Column="2" Classes="TransportBtn"
                            Command="{Binding RewindCommand}"
                            ToolTip.Tip="Rewind 10s">
                        <TextBlock Text="⏪" Foreground="#a6adc8" FontSize="11"/>
                    </Button>

                    <Button Grid.Column="3" Classes="TransportBtn"
                            Command="{Binding ForwardCommand}"
                            ToolTip.Tip="Forward 10s">
                        <TextBlock Text="⏩" Foreground="#a6adc8" FontSize="11"/>
                    </Button>

                    <Slider Grid.Column="4" Minimum="0" Maximum="200"
                            Value="{Binding Volume}" Margin="12,0"
                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="5" Text="{Binding Volume}"
                               VerticalAlignment="Center" Margin="2,0" Width="24"
                               Foreground="#a6adc8" FontSize="11"
                               HorizontalAlignment="Center"/>

                    <Button Grid.Column="6" Classes="TransportBtn"
                            Command="{Binding ToggleMuteCommand}"
                            ToolTip.Tip="Mute">
                        <TextBlock Text="{Binding IsMuted, Converter={x:Static vm:MainViewModel.MuteIcon}}"
                                   Foreground="#a6adc8" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <Button Grid.Column="7" Classes="TransportBtn"
                            ToolTip.Tip="Subtitles"
                            Click="OnCcClick">
                        <TextBlock Text="CC" Foreground="#89b4fa" FontSize="10" FontWeight="Bold"/>
                    </Button>

                    <Button Grid.Column="8" Classes="TransportBtn"
                            Command="{Binding FullscreenCommand}"
                            ToolTip.Tip="Fullscreen (F)">
                        <TextBlock Text="⛶" Foreground="#89b4fa" FontSize="13"/>
                    </Button>
                </Grid>
            </Border>
        </Popup>

        <Popup x:Name="DebugPopup" IsLightDismissEnabled="False"
               OverlayDismissEventPassThrough="True"
               HorizontalOffset="8" VerticalOffset="8">
            <Border Background="#cc11111b" CornerRadius="8" Padding="10" MinWidth="260">
                <StackPanel Spacing="3" DataContext="{Binding DebugStats}">
                    <TextBlock Text="Debug Stats" Foreground="#cba6f7" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="State" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding State}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Connection" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding ConnectionUrl}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Input Bitrate" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding InputBitrate}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Demux Bitrate" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding DemuxBitrate}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Send Bitrate" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding SendBitrate}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Sent Packets" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding SentPackets}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Displayed" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayedPictures}" Foreground="#a6e3a1" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Lost Pictures" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding LostPictures}" Foreground="#f38ba8" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Corrupted" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding DemuxCorrupted}" Foreground="#f9e2af" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Discontinuity" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding DemuxDiscontinuity}" Foreground="#f9e2af" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Grid.Column="0" Text="Data Read" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding ReadBytes}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>

        <TextBlock x:Name="StatusBar" Grid.Row="3" Text="{Binding StatusText}" Margin="10,3"
                   Foreground="#6c7086" FontSize="11"/>
    </Grid>
</Window>
