<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sabeltann.ViewModels"
        xmlns:views="using:Sabeltann.Views"
        x:Name="ThisWindow"
        xmlns:c="using:Sabeltann.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Sabeltann.MainWindow"
        Title="Sabeltann - IPTV Player"
        Background="#1e1e2e">

    <Window.Resources>
        <c:BoolToColorConverter x:Key="StarColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.TransportBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#ffffff15"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="#ffffff25"/>
            </Style>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid x:Name="MainGrid" RowDefinitions="0,Auto,*,28">

        <Grid x:Name="TitleBar" Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" Background="#181825">
            <Grid Grid.Column="0" ColumnDefinitions="Auto,Auto" Background="#181825">
            <Border Padding="14,0,12,0" Background="#181825">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="6" Background="#cba6f7">
                        <TextBlock Text="☠" Foreground="#1e1e2e" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SABELTANN" Foreground="#cdd6f4" FontSize="12"
                               FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="4,0,0,0">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                         Fill="{Binding IsConnected, Converter={x:Static vm:MainViewModel.ConnDot}}"/>
                <TextBlock Text="{Binding ConnectionLabel}" Foreground="#6c7086" FontSize="11"/>
            </StackPanel>
            </Grid>
            <Menu x:Name="MainMenu" Grid.Column="1" Background="#181825" Foreground="#cdd6f4"
                  FontSize="13">
                <MenuItem Header="_File">
                    <MenuItem Header="Load M3U URL..." Click="OnLoadM3UUrl"/>
                    <MenuItem Header="Load M3U File..." Click="OnLoadM3UFile"/>
                    <Separator/>
                    <MenuItem Header="Xtream Login..." Click="OnXtreamLogin"/>
                    <Separator/>
                    <MenuItem Header="_Settings..." Click="OnSettings"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Click="OnExit"/>
                </MenuItem>
            </Menu>
            <Border Grid.Column="2" IsVisible="{Binding ShowConnectionOverlay}"
                    VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding ConnectionState}" Foreground="#a6e3a1" FontSize="11"/>
                    <TextBlock Text="{Binding ConnectionProgress, StringFormat='{}{0}%'}" Foreground="#6c7086" FontSize="11"/>
                </StackPanel>
            </Border>
            <Button Grid.Column="3" Command="{Binding CheckForUpdatesCommand}"
                    Background="Transparent" BorderThickness="0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Check for Updates"
                    Padding="6,2"
                    Focusable="False">
                <TextBlock Text="↑" Foreground="#6c7086" FontSize="14"/>
            </Button>
        </Grid>

        <Border x:Name="CategoryBar" Grid.Row="1" Padding="10,7" Background="#313244">
            <DockPanel>
                <Menu DockPanel.Dock="Left" Background="#313244" Foreground="#cdd6f4"
                      FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0">
                    <MenuItem Header="_File">
                        <MenuItem Header="Load M3U URL..." Click="OnLoadM3UUrl"/>
                        <MenuItem Header="Load M3U File..." Click="OnLoadM3UFile"/>
                        <Separator/>
                        <MenuItem Header="Xtream Login..." Click="OnXtreamLogin"/>
                        <Separator/>
                        <MenuItem Header="_Settings..." Click="OnSettings"/>
                        <Separator/>
                        <MenuItem Header="E_xit" Click="OnExit"/>
                    </MenuItem>
                </Menu>
                <Button DockPanel.Dock="Right" Command="{Binding CheckForUpdatesCommand}"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Check for Updates"
                        Padding="6,2"
                        Focusable="False">
                    <TextBlock Text="↑" Foreground="#6c7086" FontSize="14"/>
                </Button>
                <Border DockPanel.Dock="Right" IsVisible="{Binding ShowConnectionOverlay}"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding ConnectionState}" Foreground="#a6e3a1" FontSize="11"/>
                        <TextBlock Text="{Binding ConnectionProgress, StringFormat='{}{0}%'}" Foreground="#6c7086" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                    <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                            Width="28" Height="28" Padding="0" Margin="0,0,8,0"
                            Command="{Binding GoBackCommand}"
                            IsVisible="{Binding ShowBackButton}"
                            ToolTip.Tip="Back to menu">
                        <TextBlock Text="←" Foreground="#a6adc8" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsLiveTv}">
                        <TextBlock Text="Category" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#a6adc8" LetterSpacing="1"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberBinding="{Binding Name}"
                                  MinWidth="150" FontSize="12"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="2" IsChecked="{Binding ShowFavoritesOnly}"
                                  Background="Transparent" BorderThickness="0"
                                  Margin="6,0,0,0" Padding="4,0"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding IsLiveTv}">
                        <TextBlock Text="★" Foreground="#f9e2af" FontSize="13"/>
                    </ToggleButton>
                    <TextBox Grid.Column="3" Text="{Binding SearchText}"
                             PlaceholderText="Search channels..."
                             Background="#1e1e2e" Foreground="#cdd6f4"
                             BorderThickness="1" BorderBrush="#45475a"
                             FontSize="12" Padding="6,4"
                             Margin="8,0" VerticalAlignment="Center"
                             MaxWidth="240"
                             IsVisible="{Binding IsLiveTv}"/>
                    <ToggleButton Grid.Column="4" IsChecked="{Binding ShowDebugOverlay}"
                                  Background="Transparent" BorderThickness="0"
                                  Margin="4,0" Padding="6,2"
                                  VerticalAlignment="Center">
                        <TextBlock Text="DEBUG" Foreground="#f38ba8" FontSize="9" FontWeight="Bold"
                                   LetterSpacing="1"/>
                    </ToggleButton>
                    <Border Grid.Column="5" CornerRadius="10" Background="#313244"
                            Padding="8,2" Margin="6,0" VerticalAlignment="Center"
                            IsVisible="{Binding IsLiveTv}">
                        <TextBlock Text="{Binding ChannelCount, StringFormat='{}{0} channels'}"
                                   Foreground="#a6adc8" FontSize="11"/>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="2" ColumnDefinitions="*">

            <Grid Grid.Column="0">
                <!-- Channel grid for Live TV -->
                <ListBox x:Name="ChannelGrid" IsVisible="{Binding ShowChannelGrid}"
                         ItemsSource="{Binding FilteredChannels}"
                         SelectedItem="{Binding SelectedChannel}"
                         Background="Transparent" BorderThickness="0" Padding="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0" Margin="2,2" Background="#181825"
                                    CornerRadius="10" BorderThickness="1" BorderBrush="#313244"
                                    Width="200" Height="140">
                                <Grid RowDefinitions="*,Auto">
                                    <Button Grid.Row="0" Background="Transparent" BorderThickness="0"
                                            CornerRadius="10,10,0,0" Padding="0"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            Command="{Binding $parent[Window].DataContext.SelectChannelCommand}"
                                            CommandParameter="{Binding .}">
                                        <Border Background="#313244" CornerRadius="10,10,0,0">
                                            <Grid>
                                                <Image Source="{Binding LogoSrc}" Stretch="UniformToFill"
                                                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                                <Border Width="40" Height="40" CornerRadius="10"
                                                        Background="{Binding Name, Converter={x:Static vm:MainViewModel.HashColor}}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        IsVisible="{Binding LogoSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}">
                                                    <TextBlock Text="{Binding Name, Converter={x:Static vm:MainViewModel.FirstChar}}"
                                                               Foreground="#cdd6f4" FontSize="16" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Button Background="Transparent" BorderThickness="0"
                                                        Width="28" Height="28" Padding="0"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Command="{Binding $parent[Window].DataContext.ToggleFavoriteCommand}"
                                                        CommandParameter="{Binding .}">
                                                    <TextBlock Text="★" FontSize="14"
                                                               Foreground="{Binding IsFavorite, Converter={StaticResource StarColorConverter}}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Button>
                                    <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="#cdd6f4" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="8,4"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="VideoBorder" Background="#11111b" IsVisible="{Binding ShowVideo}" ZIndex="1">
                    <Image x:Name="VideoImage" Source="{Binding VideoBitmap}" Stretch="Uniform" />
                </Border>

                <Button Background="#44000000" BorderThickness="0" CornerRadius="8"
                        Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="8" Padding="0" IsVisible="{Binding ShowVideo}"
                        Command="{Binding StopPlaybackCommand}" ZIndex="10">
                    <TextBlock Text="✕" Foreground="#f38ba8" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <views:ConnectionPage x:Name="ConnectionPage" IsVisible="{Binding IsWelcome}"/>

                <views:ContentPicker x:Name="ContentPicker" IsVisible="{Binding IsPicker}"/>
                <Border IsVisible="{Binding IsMovies}" Background="#11111b">
                    <views:VodBrowser DataContext="{Binding VodBrowser}"/>
                </Border>
                <Border IsVisible="{Binding IsSeries}" Background="#11111b">
                    <views:SeriesBrowser DataContext="{Binding SeriesBrowser}"/>
                </Border>
                <Border IsVisible="{Binding IsMovieDetail}" Background="#11111b">
                    <views:MovieDetailView DataContext="{Binding MovieDetail}"/>
                </Border>

                <!-- Pause overlay -->
                <Border x:Name="PauseOverlay" IsVisible="{Binding IsPaused}" ZIndex="10"
                        Background="#8811111b" CornerRadius="0" Padding="0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <TextBlock Text="⏸" Foreground="#cdd6f4" FontSize="48"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Paused" Foreground="#a6adc8" FontSize="18"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Buffering / error overlay -->
                <Border ZIndex="5"
                        IsVisible="{Binding ShowBufferingOverlay}"
                        Background="#f011111b"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <ProgressBar IsIndeterminate="True"
                                     MinWidth="220"
                                     Height="4"
                                     Foreground="#cba6f7"
                                     Background="#313244"/>
                        <TextBlock Text="{Binding ConnectionState}"
                                   Foreground="#cdd6f4"
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Transport bar (bottom overlay) -->
                <Border x:Name="TransportBar" IsVisible="{Binding ShowVideo}" Opacity="0"
                        Background="#cc000000" Padding="8,6"
                        HorizontalAlignment="Stretch" VerticalAlignment="Bottom" ZIndex="10"
                        PointerEntered="OnTransportEntered"
                        PointerExited="OnTransportExited">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">

                        <!-- Play/Pause -->
                        <Button Grid.Column="0" Classes="TransportBtn" Focusable="False"
                                Command="{Binding TogglePlayPauseCommand}">
                            <TextBlock Text="{Binding PlayPauseSymbol}" Foreground="#cdd6f4" FontSize="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Stop -->
                        <Button Grid.Column="1" Classes="TransportBtn" Focusable="False"
                                Command="{Binding StopCommand}">
                            <TextBlock Text="⏹" Foreground="#f38ba8" FontSize="15"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Rewind -->
                        <Button Grid.Column="2" Classes="TransportBtn" Focusable="False"
                                Command="{Binding RewindCommand}"
                                ToolTip.Tip="Rewind 10s">
                            <TextBlock Text="⏪" Foreground="#a6adc8" FontSize="15"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Forward -->
                        <Button Grid.Column="3" Classes="TransportBtn" Focusable="False"
                                Command="{Binding ForwardCommand}"
                                ToolTip.Tip="Forward 10s">
                            <TextBlock Text="⏩" Foreground="#a6adc8" FontSize="15"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Progress bar + time -->
                        <Grid Grid.Column="4" ColumnDefinitions="*,Auto" VerticalAlignment="Center" Margin="0,0,8,0"
                              IsVisible="{Binding IsVodContent}">
                            <Slider Grid.Column="0" Minimum="0" Maximum="1"
                                    Value="{Binding VodPositionPercent}"
                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       Foreground="#a6adc8" FontSize="11">
                                <Run Text="{Binding PositionText}"/><Run Text=" / "/><Run Text="{Binding DurationText}"/>
                            </TextBlock>
                        </Grid>

                        <!-- Volume button -->
                        <Button Grid.Column="5" x:Name="VolumeBtn" Classes="TransportBtn" Focusable="False"
                                Command="{Binding ToggleMuteCommand}"
                                ToolTip.Tip="Volume / click to mute (M)"
                                PointerEntered="OnVolumeBtnEntered"
                                PointerExited="OnVolumeBtnExited">
                            <TextBlock Text="{Binding IsMuted, Converter={x:Static vm:MainViewModel.MuteIcon}}"
                                       Foreground="#a6adc8" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Subtitles -->
                        <Button Grid.Column="6" Classes="TransportBtn" Focusable="False"
                                ToolTip.Tip="Subtitles"
                                Click="OnCcClick">
                            <TextBlock Text="CC" Foreground="#89b4fa" FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Fullscreen -->
                        <Button Grid.Column="7" Classes="TransportBtn" Focusable="False"
                                Command="{Binding FullscreenCommand}"
                                ToolTip.Tip="Fullscreen (F)">
                            <TextBlock Text="⛶" Foreground="#89b4fa" FontSize="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Volume slider overlay (in-window, ZIndex layer) -->
                <Border x:Name="VolumeOverlay"
                        ZIndex="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,80,52"
                        IsVisible="{Binding ShowVolumePopup}"
                        Background="#cc000000"
                        CornerRadius="6"
                        Padding="12,10"
                        PointerEntered="OnVolumePopupEntered"
                        PointerExited="OnVolumePopupExited">
                    <StackPanel Orientation="Vertical" Spacing="6">
                        <TextBlock Text="{Binding Volume}" Foreground="#a6adc8" FontSize="11"
                                   HorizontalAlignment="Center"/>
                        <Grid ColumnDefinitions="26,36">
                            <Canvas Grid.Column="0" Width="26" Height="170">
                                <TextBlock Canvas.Top="2"   Canvas.Left="0" Text="200" FontSize="9" Foreground="#6c7086"/>
                                <TextBlock Canvas.Top="43"  Canvas.Left="0" Text="150" FontSize="9" Foreground="#6c7086"/>
                                <TextBlock Canvas.Top="84"  Canvas.Left="0" Text="100" FontSize="9" Foreground="#6c7086"/>
                                <TextBlock Canvas.Top="125" Canvas.Left="0" Text="50"  FontSize="9" Foreground="#6c7086"/>
                                <TextBlock Canvas.Top="161" Canvas.Left="0" Text="0"   FontSize="9" Foreground="#6c7086"/>
                            </Canvas>
                            <Slider Grid.Column="1" Orientation="Vertical" Minimum="0" Maximum="200"
                                    Value="{Binding Volume}" Height="170"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Debug stats overlay (in-window, ZIndex layer) -->
                <Border x:Name="DebugOverlay"
                        ZIndex="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,8,52"
                        IsVisible="{Binding ShowDebugOverlay}"
                        Background="#cc11111b"
                        CornerRadius="8"
                        Padding="14,12"
                        Width="380">
                    <StackPanel Spacing="3" DataContext="{Binding DebugStats}">
                        <TextBlock Text="Debug Info" Foreground="#cba6f7" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="State" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding State}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Resolution" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Resolution}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Frames" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Frames}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Position" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Position}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Duration" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Duration}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Volume" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Volume}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Input" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding InputBitrate}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Demux" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding DemuxBitrate}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="Dropped" Foreground="#6c7086" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding LostFrames}" Foreground="#cdd6f4" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Text="URL" Foreground="#6c7086" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ConnectionUrl}" Foreground="#cdd6f4" FontSize="11"
                                       HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding ConnectionUrl}" MaxWidth="120"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>

        <Grid x:Name="StatusBar" Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" Background="#181825">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" Margin="10,3"
                       Foreground="#6c7086" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding UpdateBadgeText}"
                       Foreground="#a6e3a1" FontSize="11"
                       VerticalAlignment="Center" Margin="8,0"
                       IsVisible="{Binding IsUpdatePending}"/>
            <ProgressBar Grid.Column="2" Value="{Binding UpdateDownloadProgress}"
                         Maximum="1.0" Height="2" MinWidth="60"
                         Foreground="#cba6f7" Background="#313244"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
        </Grid>
    </Grid>
</Window>
