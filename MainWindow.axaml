<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sabeltann.ViewModels"
        xmlns:views="using:Sabeltann.Views"
        x:Name="ThisWindow"
        xmlns:c="using:Sabeltann.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Sabeltann.MainWindow"
        Title="Sabeltann - IPTV Player"
        Width="960" Height="680"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Window.Resources>
        <c:BoolToColorConverter x:Key="StarColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Video transport buttons (bottom media-controls bar) -->
        <Style Selector="Button.TransportBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#22FFFFFF"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="#33FFFFFF"/>
            </Style>
        </Style>

        <!-- Toolbar ghost / pill button -->
        <Style Selector="Button.Pill">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource Surface2}"/>
                <Setter Property="BorderBrush" Value="#3A3F4A"/>
            </Style>
        </Style>

        <!-- Amber primary button -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Segmented tab -->
        <Style Selector="ToggleButton.Tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Sub}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style Selector="^:checked /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
                <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}"/>
            </Style>
        </Style>

        <!-- Nav tab: .active is a one-way projection of the current mode, never user-toggled —
             so exactly one Live/Movies/Series tab is ever highlighted. -->
        <Style Selector="Button.NavTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Sub}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style Selector="^.active /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
                <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}"/>
            </Style>
        </Style>

        <!-- Vertical divider -->
        <Style Selector="Border.Divider">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="{StaticResource Line}"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Mono count pill -->
        <Style Selector="Border.CountPill">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Window caption buttons -->
        <Style Selector="Button.WinBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B909B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource Surface2}"/>
                <Setter Property="TextElement.Foreground" Value="{StaticResource Text}"/>
            </Style>
        </Style>
        <Style Selector="Button.WinClose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- File menu pill + flyout theming -->
        <Style Selector="Menu.FileMenu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Menu.FileMenu > MenuItem">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
        <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Panel>
    <Border CornerRadius="12" Background="{StaticResource Bg}" ClipToBounds="True">
    <Grid x:Name="MainGrid" RowDefinitions="40,54,*">

        <!-- ============ Title bar (custom chrome) ============ -->
        <Grid x:Name="TitleBar" Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto"
              Background="{StaticResource TitleBar}" PointerPressed="OnTitleBarPressed">
            <Border Grid.Column="0" Grid.ColumnSpan="4" Background="Transparent" BorderBrush="{StaticResource Line2}"
                    BorderThickness="0,0,0,1" IsHitTestVisible="False"/>

            <!-- Left: logo + wordmark + connection cluster -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="12,0"
                        VerticalAlignment="Center">
                <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource Accent}">
                    <TextBlock Text="☠" Foreground="{StaticResource AccentText}" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="SABELTANN" Foreground="#CFD3DC" FontSize="11"
                           FontFamily="Consolas" FontWeight="SemiBold" LetterSpacing="2.5"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="6,0,0,0">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding IsConnected, Converter={x:Static vm:MainViewModel.ConnDot}}"/>
                    <TextBlock Text="{Binding ConnectionHost}" Foreground="#7C828F" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <!-- Center: transient connection progress -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right"
                        Margin="0,0,10,0" VerticalAlignment="Center"
                        IsVisible="{Binding ShowConnectionOverlay}">
                <TextBlock Text="{Binding ConnectionState}" Foreground="{StaticResource Good}" FontSize="11"/>
                <TextBlock Text="{Binding ConnectionProgress, StringFormat='{}{0}%'}" Foreground="{StaticResource Muted}" FontSize="11"/>
            </StackPanel>

            <!-- Update affordance (relocated from removed status bar) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                        Margin="0,0,4,0">
                <TextBlock Text="{Binding UpdateBadgeText}" Foreground="{StaticResource Good}" FontSize="11"
                           VerticalAlignment="Center" IsVisible="{Binding IsUpdatePending}"/>
                <ProgressBar Value="{Binding UpdateDownloadProgress}" Maximum="1.0" Height="2" MinWidth="50"
                             Foreground="{StaticResource Accent}" Background="{StaticResource Line}"
                             VerticalAlignment="Center" IsVisible="{Binding IsUpdatePending}"/>
                <Button Command="{Binding CheckForUpdatesCommand}" Classes="WinBtn"
                        FontFamily="Segoe UI" FontSize="13" ToolTip.Tip="Check for Updates"
                        Focusable="False" Content="↑"/>
            </StackPanel>

            <!-- Window caption buttons (Segoe Fluent Icons: minimize / maximize / close) -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Classes="WinBtn" Content="&#xE921;" Click="OnMinimize" ToolTip.Tip="Minimize"/>
                <Button Classes="WinBtn" Content="&#xE922;" Click="OnMaximizeRestore" ToolTip.Tip="Maximize"/>
                <Button Classes="WinBtn WinClose" Content="&#xE8BB;" Click="OnCloseWindow" ToolTip.Tip="Close"/>
            </StackPanel>
        </Grid>

        <!-- ============ Morphing toolbar ============ -->
        <Border x:Name="Toolbar" Grid.Row="1" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="12,0">
            <Grid ColumnDefinitions="Auto,*">

                <!-- Left zone: File menu (browsing) OR back arrow (detail/playback) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <Menu Classes="FileMenu" IsVisible="{Binding ShowFileMenu}" VerticalAlignment="Center">
                        <MenuItem Header="☰ File">
                            <MenuItem Header="Load M3U URL..." Click="OnLoadM3UUrl"/>
                            <MenuItem Header="Load M3U File..." Click="OnLoadM3UFile"/>
                            <Separator/>
                            <MenuItem Header="Xtream Login..." Click="OnXtreamLogin"/>
                            <Separator/>
                            <MenuItem Header="Settings..." Click="OnSettings"/>
                            <Separator/>
                            <MenuItem Header="Exit" Click="OnExit"/>
                        </MenuItem>
                    </Menu>
                    <Button Classes="Pill" Width="34" Padding="0" Height="34"
                            Command="{Binding GoBackCommand}" IsVisible="{Binding ShowToolbarBack}"
                            ToolTip.Tip="Back" Content="←"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Right zone: per-mode content (stacked, one visible at a time) -->
                <!-- ponytail: opacity-only morph fade; literal 5px slide skipped (fragile to bind). -->
                <Grid x:Name="ToolbarContent" Grid.Column="1" Margin="10,0,0,0">
                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                        </Transitions>
                    </Grid.Transitions>

                    <!-- Welcome -->
                    <Grid IsVisible="{Binding IsWelcome}" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="No source connected" Foreground="{StaticResource Muted}"
                                   FontSize="12.5" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Classes="Primary" Content="＋ Connect a source"
                                Click="OnLoadM3UUrl"/>
                    </Grid>

                    <!-- Picker -->
                    <Grid IsVisible="{Binding IsPicker}" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="Choose what to watch" Foreground="#CFD3DC"
                                   FontSize="12.5" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding ConnectionLabel}" Foreground="{StaticResource Muted}"
                                   FontFamily="Consolas" FontSize="11.5" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Live TV -->
                    <Grid IsVisible="{Binding ShowLiveBar}"
                          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                            <Button Classes="NavTab" Classes.active="{Binding IsLiveTv}" Content="▦ Live TV" Command="{Binding SwitchToLiveCommand}"/>
                            <Button Classes="NavTab" Classes.active="{Binding IsMovies}" Content="▷ Movies" Command="{Binding SwitchToMoviesCommand}"/>
                            <Button Classes="NavTab" Classes.active="{Binding IsSeries}" Content="⊞ Series" Command="{Binding SwitchToSeriesCommand}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="Divider"/>
                        <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberBinding="{Binding Name}" MinWidth="150" FontSize="12"
                                  VerticalAlignment="Center"/>
                        <ToggleButton Grid.Column="3" IsChecked="{Binding ShowFavoritesOnly}" Classes="Tab"
                                      Content="★" Margin="4,0" ToolTip.Tip="Favorites only"/>
                        <ToggleButton Grid.Column="4" IsChecked="{Binding IsTimeline}" Classes="Tab"
                                      Content="🗓 Guide" Margin="4,0" Command="{Binding ToggleTimelineCommand}"
                                      IsVisible="{Binding CanUseTimeline}" ToolTip.Tip="EPG timeline (TV guide)"/>
                        <TextBox Grid.Column="5" Text="{Binding SearchText}" PlaceholderText="⌕ Search channels…"
                                 Background="{StaticResource InputBg}" Foreground="{StaticResource Text}"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8"
                                 FontSize="12" Padding="8,5" Margin="8,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="6" Classes="CountPill">
                            <TextBlock Text="{Binding ChannelCount, StringFormat='{}{0} ch'}"
                                       Foreground="{StaticResource Sub}" FontFamily="Consolas" FontSize="11"/>
                        </Border>
                    </Grid>

                    <!-- Movies -->
                    <Grid IsVisible="{Binding ShowMoviesBar}"
                          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                            <Button Classes="NavTab" Classes.active="{Binding IsLiveTv}" Content="▦ Live TV" Command="{Binding SwitchToLiveCommand}"/>
                            <Button Classes="NavTab" Classes.active="{Binding IsMovies}" Content="▷ Movies" Command="{Binding SwitchToMoviesCommand}"/>
                            <Button Classes="NavTab" Classes.active="{Binding IsSeries}" Content="⊞ Series" Command="{Binding SwitchToSeriesCommand}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="Divider"/>
                        <TextBlock Grid.Column="2" Text="Category:" Foreground="{StaticResource Muted}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding VodBrowser.Categories}"
                                  SelectedItem="{Binding VodBrowser.SelectedCategory}"
                                  MinWidth="140" MaxWidth="220" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Sort by:" Foreground="{StaticResource Muted}" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <ComboBox Grid.Column="5" ItemsSource="{Binding VodBrowser.SortOptions}"
                                  SelectedItem="{Binding VodBrowser.SelectedSort}"
                                  MinWidth="120" FontSize="12" VerticalAlignment="Center"
                                  ToolTip.Tip="Ratings need OMDb; unrated titles sink"/>
                        <TextBox Grid.Column="6" Text="{Binding VodBrowser.SearchText}" PlaceholderText="⌕ Search movies…"
                                 Background="{StaticResource InputBg}" Foreground="{StaticResource Text}"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8"
                                 FontSize="12" Padding="8,5" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Series -->
                    <Grid IsVisible="{Binding ShowSeriesBar}"
                          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                            <Button Classes="NavTab" Classes.active="{Binding IsLiveTv}" Content="▦ Live TV" Command="{Binding SwitchToLiveCommand}"/>
                            <Button Classes="NavTab" Classes.active="{Binding IsMovies}" Content="▷ Movies" Command="{Binding SwitchToMoviesCommand}"/>
                            <Button Classes="NavTab" Classes.active="{Binding IsSeries}" Content="⊞ Series" Command="{Binding SwitchToSeriesCommand}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="Divider"/>
                        <TextBlock Grid.Column="2" Text="Category:" Foreground="{StaticResource Muted}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0" IsVisible="{Binding SeriesBrowser.ShowShows}"/>
                        <ComboBox Grid.Column="3" ItemsSource="{Binding SeriesBrowser.Categories}"
                                  SelectedItem="{Binding SeriesBrowser.SelectedCategory}"
                                  MinWidth="140" MaxWidth="220" FontSize="12" VerticalAlignment="Center"
                                  IsVisible="{Binding SeriesBrowser.ShowShows}"/>
                        <TextBlock Grid.Column="4" Text="Sort by:" Foreground="{StaticResource Muted}" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,6,0" IsVisible="{Binding SeriesBrowser.ShowShows}"/>
                        <ComboBox Grid.Column="5" ItemsSource="{Binding SeriesBrowser.SortOptions}"
                                  SelectedItem="{Binding SeriesBrowser.SelectedSort}"
                                  MinWidth="120" FontSize="12" VerticalAlignment="Center"
                                  IsVisible="{Binding SeriesBrowser.ShowShows}"
                                  ToolTip.Tip="Ratings need OMDb; unrated titles sink"/>
                        <TextBox Grid.Column="6" Text="{Binding SeriesBrowser.SearchText}" PlaceholderText="⌕ Search shows…"
                                 Background="{StaticResource InputBg}" Foreground="{StaticResource Text}"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8"
                                 FontSize="12" Padding="8,5" Margin="12,0,0,0" VerticalAlignment="Center"
                                 IsVisible="{Binding SeriesBrowser.ShowShows}"/>
                    </Grid>

                    <!-- Movie/Series detail -->
                    <Grid IsVisible="{Binding ShowDetailBar}" ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="{Binding MovieDetail.Title}" Foreground="{StaticResource TextStrong}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                        <Button Grid.Column="2" Classes="Pill" Content="{Binding MovieDetail.ResumeText}"
                                Command="{Binding ResumeFromDetailCommand}" Margin="0,0,8,0"
                                IsVisible="{Binding MovieDetail.CanResume}"/>
                        <Button Grid.Column="3" Classes="Primary" Content="▶ Play"
                                Command="{Binding PlayFromStartCommand}"/>
                    </Grid>

                    <!-- Playback (left info only; controls live in the bottom media bar) -->
                    <StackPanel IsVisible="{Binding ShowPlaybackBar}" Orientation="Horizontal" Spacing="10"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPlayingTitle}" Foreground="{StaticResource TextStrong}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                        <Border CornerRadius="5" Padding="7,2" VerticalAlignment="Center"
                                Background="{StaticResource Live}" IsVisible="{Binding !IsCurrentVod}">
                            <TextBlock Text="LIVE" Foreground="#FFFFFF" FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <Border CornerRadius="5" Padding="7,2" VerticalAlignment="Center"
                                Background="{StaticResource Accent}" IsVisible="{Binding IsCurrentVod}">
                            <TextBlock Text="VOD" Foreground="{StaticResource AccentText}" FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ============ Content ============ -->
        <Grid x:Name="ContentGrid" Grid.Row="2" ColumnDefinitions="*">

            <Grid Grid.Column="0">
                <!-- Channel grid for Live TV -->
                <ListBox x:Name="ChannelGrid" IsVisible="{Binding ShowChannelGrid}"
                         ItemsSource="{Binding FilteredChannels}"
                         SelectedItem="{Binding SelectedChannel}"
                         Background="Transparent" BorderThickness="0" Padding="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="11" Margin="4" Background="{StaticResource Surface}"
                                    CornerRadius="11" BorderThickness="1" BorderBrush="{StaticResource Line}"
                                    Width="175" Height="66">
                                <Grid ColumnDefinitions="38,*" ColumnSpacing="10">
                                    <Button Grid.Column="0" Grid.ColumnSpan="2" Background="Transparent"
                                            BorderThickness="0" Padding="0"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                            Command="{Binding $parent[Window].DataContext.SelectChannelCommand}"
                                            CommandParameter="{Binding .}">
                                        <Grid ColumnDefinitions="38,*" ColumnSpacing="10">
                                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="8"
                                                    Background="{Binding Name, Converter={x:Static vm:MainViewModel.HashColor}}"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <Image Source="{Binding LogoSrc}" Stretch="UniformToFill"/>
                                                    <TextBlock Text="{Binding Name, Converter={x:Static vm:MainViewModel.FirstChar}}"
                                                               Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               IsVisible="{Binding LogoSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Button>
                                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                                            Width="26" Height="26" Padding="0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Command="{Binding $parent[Window].DataContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding .}">
                                        <TextBlock Text="★" FontSize="13"
                                                   Foreground="{Binding IsFavorite, Converter={StaticResource StarColorConverter}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- EPG timeline for Live TV (toggled with the channel grid) -->
                <Border IsVisible="{Binding ShowTimeline}" Background="{StaticResource Bg}">
                    <views:EpgTimeline DataContext="{Binding EpgTimeline}"/>
                </Border>

                <Border x:Name="VideoBorder" Background="#0B0C0F" IsVisible="{Binding ShowVideo}" ZIndex="1">
                    <Grid>
                        <Image x:Name="VideoImage" Source="{Binding VideoBitmap}" Stretch="Uniform" />
                        <!-- Shown while the video is detached into the pop-out window. -->
                        <StackPanel x:Name="PopoutPlaceholder" IsVisible="False"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                            <TextBlock Text="🗗" FontSize="44" Foreground="{StaticResource Sub}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Playing in pop-out window" Foreground="{StaticResource Text}"
                                       FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Close the pop-out (or press Esc) to return it here"
                                       Foreground="{StaticResource Muted}" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <views:ConnectionPage x:Name="ConnectionPage" IsVisible="{Binding IsWelcome}"/>

                <views:ContentPicker x:Name="ContentPicker" IsVisible="{Binding IsPicker}"/>
                <Border IsVisible="{Binding IsMovies}" Background="{StaticResource Bg}">
                    <views:VodBrowser DataContext="{Binding VodBrowser}"/>
                </Border>
                <Border IsVisible="{Binding IsSeries}" Background="{StaticResource Bg}">
                    <views:SeriesBrowser DataContext="{Binding SeriesBrowser}"/>
                </Border>
                <Border IsVisible="{Binding IsMovieDetail}" Background="{StaticResource Bg}">
                    <views:MovieDetailView DataContext="{Binding MovieDetail}"/>
                </Border>

                <!-- Pause overlay: amber ring + play glyph. Click anywhere to resume. -->
                <Border x:Name="PauseOverlay" IsVisible="{Binding ShowPauseOverlay}" ZIndex="10"
                        Background="#990B0C0F" Cursor="Hand" PointerPressed="OnPauseOverlayPressed">
                    <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource Accent}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="▶" Foreground="{StaticResource AccentText}" FontSize="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Border>

                <!-- Casting overlay -->
                <Border x:Name="CastOverlay" IsVisible="{Binding IsCasting}" ZIndex="9"
                        IsHitTestVisible="False" Background="#CC0B0C0F">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <TextBlock Text="📺" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Chromecasting…" Foreground="{StaticResource Text}" FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CastTargetName}" Foreground="{StaticResource Sub}" FontSize="14"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Buffering / error overlay -->
                <Border ZIndex="5" IsVisible="{Binding ShowBufferingOverlay}" Background="#F00B0C0F"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <ProgressBar IsIndeterminate="True" MinWidth="220" Height="4"
                                     Foreground="{StaticResource Accent}" Background="{StaticResource Line}"/>
                        <TextBlock Text="{Binding ConnectionState}" Foreground="{StaticResource Text}"
                                   FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Bottom media-controls bar (kept, recolored) -->
                <Border x:Name="TransportBar" IsVisible="{Binding ShowVideo}" Opacity="0"
                        Background="#CC101216" Padding="8,6"
                        HorizontalAlignment="Stretch" VerticalAlignment="Bottom" ZIndex="10"
                        PointerEntered="OnTransportEntered" PointerExited="OnTransportExited">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">

                        <Button Grid.Column="0" Classes="TransportBtn" Focusable="False"
                                Command="{Binding TogglePlayPauseCommand}">
                            <PathIcon Data="{Binding IsPlaying, Converter={x:Static vm:MainViewModel.PlayPauseIcon}}"
                                      Foreground="{StaticResource Text}" Width="17" Height="17"/>
                        </Button>

                        <Button Grid.Column="1" Classes="TransportBtn" Focusable="False"
                                Command="{Binding StopPlaybackCommand}">
                            <PathIcon Data="{x:Static vm:MainViewModel.StopGeo}" Foreground="{StaticResource Danger}"
                                      Width="15" Height="15"/>
                        </Button>

                        <Button Grid.Column="2" Classes="TransportBtn" Focusable="False"
                                Command="{Binding RewindCommand}" ToolTip.Tip="Rewind 10s">
                            <PathIcon Data="{x:Static vm:MainViewModel.RewindGeo}" Foreground="{StaticResource Sub}"
                                      Width="17" Height="17"/>
                        </Button>

                        <Button Grid.Column="3" Classes="TransportBtn" Focusable="False"
                                Command="{Binding ForwardCommand}" ToolTip.Tip="Forward 10s">
                            <PathIcon Data="{x:Static vm:MainViewModel.ForwardGeo}" Foreground="{StaticResource Sub}"
                                      Width="17" Height="17"/>
                        </Button>

                        <Grid Grid.Column="4" ColumnDefinitions="*,Auto" VerticalAlignment="Center" Margin="0,0,8,0"
                              IsVisible="{Binding IsVodContent}">
                            <Slider Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding VodPositionPercent}"
                                    Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource Sub}" FontSize="11">
                                <Run Text="{Binding PositionText}"/><Run Text=" / "/><Run Text="{Binding DurationText}"/>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="5" x:Name="VolumeBtn" Classes="TransportBtn" Focusable="False"
                                Command="{Binding ToggleMuteCommand}" ToolTip.Tip="Volume / click to mute (M)"
                                PointerEntered="OnVolumeBtnEntered" PointerExited="OnVolumeBtnExited">
                            <PathIcon Data="{Binding IsMuted, Converter={x:Static vm:MainViewModel.MuteIcon}}"
                                      Width="17" Height="17" Foreground="{StaticResource Sub}"/>
                        </Button>

                        <Button Grid.Column="6" Classes="TransportBtn" Focusable="False"
                                ToolTip.Tip="Audio track / language" Click="OnAudioClick">
                            <TextBlock Text="🎧" Foreground="{StaticResource Info}" FontSize="15"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <Button Grid.Column="7" Classes="TransportBtn" Focusable="False"
                                ToolTip.Tip="Subtitles" Click="OnCcClick">
                            <TextBlock Text="CC" Foreground="{StaticResource Info}" FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <Button Grid.Column="8" Classes="TransportBtn" Focusable="False"
                                ToolTip.Tip="Cast to device" Click="OnCastClick">
                            <TextBlock Text="📺"
                                       Foreground="{Binding IsCasting, Converter={x:Static vm:MainViewModel.CastIcon}}"
                                       FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <ToggleButton Grid.Column="9" IsChecked="{Binding ShowDebugOverlay}" Classes="TransportBtn"
                                      Focusable="False" ToolTip.Tip="Debug overlay (D)">
                            <PathIcon Data="{x:Static vm:MainViewModel.DebugGeo}" Foreground="{StaticResource Text}"
                                      Width="17" Height="17"/>
                        </ToggleButton>

                        <Button Grid.Column="10" Classes="TransportBtn" Focusable="False"
                                Click="OnPopoutClick" ToolTip.Tip="Pop-out player — detach into a floating window (Esc to return)">
                            <PathIcon Data="{x:Static vm:MainViewModel.PopoutGeo}" Foreground="{StaticResource Info}"
                                      Width="17" Height="17"/>
                        </Button>

                        <Button Grid.Column="11" Classes="TransportBtn" Focusable="False"
                                Command="{Binding FullscreenCommand}" ToolTip.Tip="Fullscreen (F)">
                            <PathIcon Data="{x:Static vm:MainViewModel.FullscreenGeo}" Foreground="{StaticResource Info}"
                                      Width="18" Height="18"/>
                        </Button>

                        <!-- Record live to file (keeps playing while recording): red dot recording,
                             hollow ring idle; while recording the tooltip shows elapsed. (#84) -->
                        <Button Grid.Column="12" Classes="TransportBtn" Focusable="False"
                                Command="{Binding ToggleRecordCommand}"
                                ToolTip.Tip="{Binding RecordingElapsed, StringFormat='Recording {0} — click to stop'}">
                            <Panel Width="14" Height="14">
                                <Ellipse Width="13" Height="13" Fill="{StaticResource Live}"
                                         IsVisible="{Binding IsRecording}"/>
                                <Ellipse Width="13" Height="13" Stroke="{StaticResource Sub}" StrokeThickness="1.5"
                                         IsVisible="{Binding !IsRecording}"/>
                            </Panel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Volume slider overlay -->
                <Border x:Name="VolumeOverlay" ZIndex="20" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,80,52" IsVisible="{Binding ShowVolumePopup}"
                        Background="#CC101216" CornerRadius="8" Padding="12,10"
                        PointerEntered="OnVolumePopupEntered" PointerExited="OnVolumePopupExited">
                    <StackPanel Orientation="Vertical" Spacing="6">
                        <TextBlock Text="{Binding Volume}" Foreground="{StaticResource Sub}" FontSize="11"
                                   HorizontalAlignment="Center"/>
                        <Grid ColumnDefinitions="26,36">
                            <Canvas Grid.Column="0" Width="26" Height="170">
                                <TextBlock Canvas.Top="2"   Canvas.Left="0" Text="200" FontSize="9" Foreground="{StaticResource Muted}"/>
                                <TextBlock Canvas.Top="43"  Canvas.Left="0" Text="150" FontSize="9" Foreground="{StaticResource Muted}"/>
                                <TextBlock Canvas.Top="84"  Canvas.Left="0" Text="100" FontSize="9" Foreground="{StaticResource Muted}"/>
                                <TextBlock Canvas.Top="125" Canvas.Left="0" Text="50"  FontSize="9" Foreground="{StaticResource Muted}"/>
                                <TextBlock Canvas.Top="161" Canvas.Left="0" Text="0"   FontSize="9" Foreground="{StaticResource Muted}"/>
                            </Canvas>
                            <Slider Grid.Column="1" Orientation="Vertical" Minimum="0" Maximum="200"
                                    Value="{Binding Volume}" Height="170"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Debug stats overlay -->
                <Border x:Name="DebugOverlay" ZIndex="20" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,8,52" IsVisible="{Binding ShowDebugOverlay}"
                        Background="#D9101216" BorderBrush="{StaticResource Line}" BorderThickness="1"
                        CornerRadius="9" Padding="14,12" Width="250">
                    <StackPanel Spacing="3" DataContext="{Binding DebugStats}">
                        <TextBlock Text="DEBUG" Foreground="{StaticResource Accent}" FontFamily="Consolas"
                                   FontSize="12" FontWeight="Bold" LetterSpacing="1" Margin="0,0,0,4"/>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="State" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding State}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Resolution" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Resolution}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Input bitrate" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding InputBitrate}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Demux bitrate" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding DemuxBitrate}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Position" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Position}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Duration" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Duration}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Volume" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Volume}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Frames" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Frames}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Grid.Column="0" Text="Dropped" Foreground="{StaticResource Muted}" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding LostFrames}" Foreground="{StaticResource Text}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </Grid>
    </Border>

        <!-- Resize grips (SystemDecorations=None removes native resize borders) -->
        <Grid ZIndex="100">
            <Border HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="5" Background="Transparent"
                    Cursor="SizeWestEast" Tag="West" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="5" Background="Transparent"
                    Cursor="SizeWestEast" Tag="East" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="5" Background="Transparent"
                    Cursor="SizeNorthSouth" Tag="North" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="5" Background="Transparent"
                    Cursor="SizeNorthSouth" Tag="South" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Width="9" Height="9" Background="Transparent"
                    Cursor="TopLeftCorner" Tag="NorthWest" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="9" Height="9" Background="Transparent"
                    Cursor="TopRightCorner" Tag="NorthEast" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="9" Height="9" Background="Transparent"
                    Cursor="BottomLeftCorner" Tag="SouthWest" PointerPressed="OnResizePressed"/>
            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="9" Height="9" Background="Transparent"
                    Cursor="BottomRightCorner" Tag="SouthEast" PointerPressed="OnResizePressed"/>
        </Grid>

        <!-- Transient toast — auto-hides. Clickable to copy when ToastCanCopy (e.g. recording path). (#94, #84) -->
        <Border ZIndex="200" IsVisible="{Binding ShowToast}" IsHitTestVisible="{Binding ToastCanCopy}"
                Cursor="Hand" PointerPressed="OnToastClick"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,52,0,0"
                Background="{StaticResource Surface2}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                CornerRadius="10" Padding="16,10" BoxShadow="0 6 20 0 #66000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="📋" FontSize="13" VerticalAlignment="Center" IsVisible="{Binding ToastCanCopy}"/>
                <TextBlock Text="{Binding ToastMessage}" Foreground="{StaticResource TextStrong}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Panel>
</Window>
