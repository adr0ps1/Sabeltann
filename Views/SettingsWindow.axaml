<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Sabeltann.Views.SettingsWindow"
        Title="Settings"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1e1e2e"
        Foreground="#cdd6f4">
    <StackPanel Margin="20" Spacing="16" MinWidth="360">
        <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="#cdd6f4"/>

        <StackPanel Spacing="6">
            <TextBlock Text="Default Volume" FontSize="13" FontWeight="SemiBold" Foreground="#cdd6f4"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="200"
                        Background="#313244" Foreground="#cba6f7"
                        BorderThickness="0"/>
                <TextBlock Grid.Column="1" Text="{Binding #VolumeSlider.Value, StringFormat='{}{0:0}%'}"
                           Foreground="#a6adc8" FontSize="13" VerticalAlignment="Center" Width="40"/>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Startup" FontSize="13" FontWeight="SemiBold" Foreground="#cdd6f4"/>
            <CheckBox x:Name="AutoLoadCheck" Content="Auto-load last session on startup"
                      Foreground="#cdd6f4" FontSize="12"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Current Connection" FontSize="13" FontWeight="SemiBold" Foreground="#cdd6f4"/>
            <Border Background="#313244" CornerRadius="6" Padding="10">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="Server:" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock x:Name="ServerUrlText" Foreground="#cdd6f4" FontSize="11"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="User:" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock x:Name="UsernameText" Foreground="#cdd6f4" FontSize="11"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="Channels:" Foreground="#6c7086" FontSize="11"/>
                        <TextBlock x:Name="ChannelCountText" Foreground="#cdd6f4" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Updates" Foreground="#6c7086" FontSize="11" FontWeight="SemiBold"/>
            <CheckBox x:Name="CheckForUpdatesCheck" Content="Check for updates automatically"
                      Foreground="#cdd6f4" FontSize="12"/>
            <CheckBox x:Name="IncludePrereleaseCheck" Content="Include prerelease versions"
                      Foreground="#cdd6f4" FontSize="12"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Cancel" Click="OnCancel"
                    Background="#313244" Foreground="#cdd6f4"
                    BorderThickness="0" CornerRadius="8" Padding="10,7" FontSize="13"/>
            <Button Grid.Column="1" Content="Save" Click="OnSave" IsDefault="True"
                    Background="#cba6f7" Foreground="#1e1e2e"
                    BorderThickness="0" CornerRadius="8" Padding="10,7" FontSize="13" FontWeight="SemiBold"/>
        </Grid>
    </StackPanel>
</Window>
