<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Sabeltann.Views.SettingsWindow"
        Title="Settings"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Foreground="{StaticResource Text}">
    <Border CornerRadius="12" Background="{StaticResource Bg}" ClipToBounds="True">
    <Grid RowDefinitions="36,*">
        <Grid Grid.Row="0" Background="{StaticResource TitleBar}" ColumnDefinitions="*,Auto"
              PointerPressed="OnChromeDrag">
            <TextBlock Grid.Column="0" Text="Settings" Foreground="{StaticResource Sub}" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0"/>
            <Button Grid.Column="1" Classes="DialogClose" Content="&#xE8BB;" Click="OnCancel"/>
        </Grid>
    <StackPanel Grid.Row="1" Margin="20" Spacing="16">
        <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>

        <StackPanel Spacing="6">
            <TextBlock Text="Default Volume" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="200"
                        Foreground="{StaticResource Accent}" BorderThickness="0"/>
                <TextBlock Grid.Column="1" Text="{Binding #VolumeSlider.Value, StringFormat='{}{0:0}%'}"
                           Foreground="{StaticResource Sub}" FontSize="13" VerticalAlignment="Center" Width="40"/>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Startup" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
            <CheckBox x:Name="AutoLoadCheck" Content="Auto-load last session on startup"
                      Foreground="{StaticResource Text}" FontSize="12"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Current Connection" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                    CornerRadius="8" Padding="10">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="Server:" Foreground="{StaticResource Muted}" FontSize="11"/>
                        <TextBlock x:Name="ServerUrlText" Grid.Column="1" Foreground="{StaticResource Text}" FontSize="11"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="User:" Foreground="{StaticResource Muted}" FontSize="11"/>
                        <TextBlock x:Name="UsernameText" Grid.Column="1" Foreground="{StaticResource Text}" FontSize="11"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="Channels:" Foreground="{StaticResource Muted}" FontSize="11"/>
                        <TextBlock x:Name="ChannelCountText" Grid.Column="1" Foreground="{StaticResource Text}" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Movie Info (OMDb)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
            <TextBox x:Name="OmdbKeyText" PlaceholderText="OMDb API key"
                     Background="{StaticResource Surface}" Foreground="{StaticResource Text}"
                     BorderThickness="1" BorderBrush="{StaticResource Line}"
                     CornerRadius="8" Padding="8,6" FontSize="12"/>
            <TextBlock Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                       Text="Free key from omdbapi.com/apikey.aspx (FREE tier). Enables ratings, plot, cast and language on the movie page."/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Updates" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="SemiBold"/>
            <CheckBox x:Name="CheckForUpdatesCheck" Content="Check for updates automatically"
                      Foreground="{StaticResource Text}" FontSize="12"/>
            <CheckBox x:Name="IncludePrereleaseCheck" Content="Include prerelease versions"
                      Foreground="{StaticResource Text}" FontSize="12"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Cancel" Click="OnCancel"
                    Background="{StaticResource Surface2}" Foreground="{StaticResource Text}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    BorderThickness="0" CornerRadius="8" Padding="10,7" FontSize="13"/>
            <Button Grid.Column="1" Content="Save" Click="OnSave" IsDefault="True"
                    Background="{StaticResource Accent}" Foreground="{StaticResource AccentText}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    BorderThickness="0" CornerRadius="8" Padding="10,7" FontSize="13" FontWeight="SemiBold"/>
        </Grid>
    </StackPanel>
    </Grid>
    </Border>
</Window>
