<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Sabeltann.Views.UpdateDialog"
        Title="Update Available"
        Width="440" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Foreground="{StaticResource Text}">

    <Border CornerRadius="12" Background="{StaticResource Bg}" ClipToBounds="True">
    <Grid RowDefinitions="36,*">
        <Grid Grid.Row="0" Background="{StaticResource TitleBar}" ColumnDefinitions="*,Auto"
              PointerPressed="OnChromeDrag">
            <TextBlock Grid.Column="0" Text="Update Available" Foreground="{StaticResource Sub}" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0"/>
            <Button Grid.Column="1" Classes="DialogClose" Content="&#xE8BB;" Click="OnChromeClose"/>
        </Grid>
    <StackPanel Grid.Row="1" Margin="24,20,24,20" Spacing="16">

        <TextBlock Text="Update Available" Foreground="{StaticResource TextStrong}" FontSize="18" FontWeight="Bold"/>

        <TextBlock FontSize="13">
            <Run Text="{Binding CurrentVersion}" Foreground="{StaticResource Sub}"/>
            <Run Text=" → " Foreground="{StaticResource Muted}"/>
            <Run Text="{Binding NewVersion}" Foreground="{StaticResource Good}" FontWeight="SemiBold"/>
        </TextBlock>

        <StackPanel IsVisible="{Binding HasReleaseNotes}" Spacing="6">
            <TextBlock Text="WHAT'S NEW" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="SemiBold"/>
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                    CornerRadius="8" Padding="10,8" MaxHeight="160">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding ReleaseNotes}" Foreground="{StaticResource Sub}" FontSize="12"
                               TextWrapping="Wrap" LineHeight="20"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <Grid/>

        <!-- Installing status: shown after Install & Restart so the silent, apply-on-exit update
             doesn't look frozen. (#80) -->
        <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsInstalling}">
            <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                         Foreground="{StaticResource Accent}" Background="{StaticResource Line}"
                         VerticalAlignment="Center"/>
            <TextBlock Text="Installing update — the app will restart…" Foreground="{StaticResource Sub}"
                       FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                    IsEnabled="{Binding !IsInstalling}">
            <Button Content="Remind Later" Command="{Binding RemindLaterCommand}"
                    Background="{StaticResource Surface2}" Foreground="{StaticResource Sub}"
                    BorderThickness="0" CornerRadius="8" Padding="12,8"/>
            <Button Content="Install on Exit" Command="{Binding InstallOnExitCommand}"
                    Background="{StaticResource Surface2}" Foreground="{StaticResource Info}"
                    BorderThickness="0" CornerRadius="8" Padding="12,8"/>
            <Button Content="Install &amp; Restart" Command="{Binding InstallAndRestartCommand}"
                    Background="{StaticResource Accent}" Foreground="{StaticResource AccentText}" FontWeight="Bold"
                    BorderThickness="0" CornerRadius="8" Padding="12,8"/>
        </StackPanel>

    </StackPanel>
    </Grid>
    </Border>
</Window>
