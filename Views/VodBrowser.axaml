<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sabeltann.ViewModels"
             x:Name="Root"
             x:Class="Sabeltann.Views.VodBrowser">
    <!-- Filters (category / search / count) live in the app's morphing toolbar. -->
    <Grid Background="{StaticResource Bg}" RowDefinitions="Auto,*,Auto">

        <!-- Continue Watching strip -->
        <StackPanel Grid.Row="0" Margin="16,10,16,0" Spacing="6"
                    IsVisible="{Binding ShowContinueWatching}">
            <TextBlock Text="Continue Watching" Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ContinueWatching}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:VodMovieViewModel}">
                            <Button Background="{StaticResource Surface}" BorderThickness="1" BorderBrush="{StaticResource Line}"
                                    CornerRadius="10" Padding="0" Margin="0,0,10,4" Width="120"
                                    EffectiveViewportChanged="OnPosterViewport"
                                    Command="{Binding #Root.DataContext.ResumeMovieCommand}"
                                    CommandParameter="{Binding .}">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Remove from Continue Watching"
                                                  Click="OnRemoveContinueWatching"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel>
                                    <Border Height="150" Background="{StaticResource Surface2}" CornerRadius="10,10,0,0">
                                        <Grid>
                                            <Image Source="{Binding PosterSrc}" Stretch="UniformToFill"
                                                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            <TextBlock Text="{Binding Initial}"
                                                       Foreground="{StaticResource Muted}" FontSize="32" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding PosterSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                            <ProgressBar Maximum="1" Value="{Binding ProgressFraction}"
                                                         Height="4" VerticalAlignment="Bottom"
                                                         Foreground="{StaticResource Accent}" Background="#80232730"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="11"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                               Margin="8,6,8,8"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel Margin="16,12">
                <ItemsControl ItemsSource="{Binding Movies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:VodMovieViewModel}">
                            <Button Background="{StaticResource Surface}" BorderThickness="1" BorderBrush="{StaticResource Line}"
                                    CornerRadius="12" Padding="0" Margin="6,6" Width="160"
                                    EffectiveViewportChanged="OnPosterViewport"
                                    Command="{Binding #Root.DataContext.PlayMovieCommand}"
                                    CommandParameter="{Binding .}">
                                <StackPanel>
                                    <Border Height="200" Background="{StaticResource Surface2}" CornerRadius="12,12,0,0">
                                        <Grid>
                                            <Image Source="{Binding PosterSrc}" Stretch="UniformToFill"
                                                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            <TextBlock Text="{Binding Initial}"
                                                       Foreground="{StaticResource Muted}" FontSize="42" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding PosterSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="10,8" Spacing="2">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="12"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding YearDisplay}" Foreground="{StaticResource Muted}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="1" IsVisible="{Binding IsLoading}" Background="#CC14161B"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Text}" FontSize="14"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" MinWidth="200" Height="4"
                             Foreground="{StaticResource Accent}" Background="{StaticResource Line}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="Press Escape to go back" Foreground="{StaticResource Muted}" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,8"/>
    </Grid>
</UserControl>
