<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sabeltann.ViewModels"
             x:Name="Root"
             x:Class="Sabeltann.Views.VodBrowser">
    <Grid Background="#11111b" RowDefinitions="Auto,Auto,*,Auto">

        <!-- Combined header + filter bar -->
        <Border Grid.Row="0" Padding="10,7" Background="#313244" BorderThickness="0,0,0,1" BorderBrush="#45475a">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Width="28" Height="28" Padding="0" Margin="0,0,6,0"
                        Command="{Binding $parent[Window].DataContext.GoBackCommand}"
                        ToolTip.Tip="Go back">
                    <TextBlock Text="←" Foreground="#a6adc8" FontSize="14"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <TextBlock Grid.Column="1" Text="Movies" Foreground="#cdd6f4" FontSize="13"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="Category" VerticalAlignment="Center"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#a6adc8" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          MinWidth="150" FontSize="12" MaxWidth="250"/>
                <TextBox Grid.Column="4" Text="{Binding SearchText}"
                         PlaceholderText="Search movies..."
                         Background="#1e1e2e" Foreground="#cdd6f4"
                         BorderThickness="1" BorderBrush="#45475a"
                         FontSize="12" Padding="6,4"
                         Margin="8,0" VerticalAlignment="Center"/>
                <Border Grid.Column="5" CornerRadius="10" Background="#313244"
                        Padding="8,2" Margin="6,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Foreground="#a6adc8" FontSize="11"/>
                </Border>
            </Grid>
        </Border>

        <!-- Continue Watching strip -->
        <StackPanel Grid.Row="1" Margin="16,10,16,0" Spacing="6"
                    IsVisible="{Binding ShowContinueWatching}">
            <TextBlock Text="Continue Watching" Foreground="#cdd6f4" FontSize="13" FontWeight="SemiBold"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ContinueWatching}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:VodMovieViewModel}">
                            <Button Background="#181825" BorderThickness="1" BorderBrush="#313244"
                                    CornerRadius="10" Padding="0" Margin="0,0,10,4" Width="120"
                                    EffectiveViewportChanged="OnPosterViewport"
                                    Command="{Binding #Root.DataContext.ResumeMovieCommand}"
                                    CommandParameter="{Binding .}">
                                <StackPanel>
                                    <Border Height="150" Background="#313244" CornerRadius="10,10,0,0">
                                        <Grid>
                                            <Image Source="{Binding PosterSrc}" Stretch="UniformToFill"
                                                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            <TextBlock Text="{Binding Initial}"
                                                       Foreground="#6c7086" FontSize="32" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding PosterSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                            <ProgressBar Maximum="1" Value="{Binding ProgressFraction}"
                                                         Height="4" VerticalAlignment="Bottom"
                                                         Foreground="#cba6f7" Background="#80313244"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="#cdd6f4" FontSize="11"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                               Margin="8,6,8,8"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel Margin="16,12">
                <ItemsControl ItemsSource="{Binding Movies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:VodMovieViewModel}">
                            <Button Background="#181825" BorderThickness="1" BorderBrush="#313244"
                                    CornerRadius="12" Padding="0" Margin="6,6" Width="160"
                                    EffectiveViewportChanged="OnPosterViewport"
                                    Command="{Binding #Root.DataContext.PlayMovieCommand}"
                                    CommandParameter="{Binding .}">
                                <StackPanel>
                                    <Border Height="200" Background="#313244" CornerRadius="12,12,0,0">
                                        <Grid>
                                            <Image Source="{Binding PosterSrc}" Stretch="UniformToFill"
                                                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            <TextBlock Text="{Binding Initial}"
                                                       Foreground="#6c7086" FontSize="42" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding PosterSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="10,8" Spacing="2">
                                        <TextBlock Text="{Binding Name}" Foreground="#cdd6f4" FontSize="12"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding YearDisplay}" Foreground="#6c7086" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="2" IsVisible="{Binding IsLoading}" Background="#cc11111b"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="{Binding StatusText}" Foreground="#cdd6f4" FontSize="14"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" MinWidth="200" Height="4"
                             Foreground="#cba6f7" Background="#313244"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="Press Escape to go back" Foreground="#45475a" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,8"/>
    </Grid>
</UserControl>
