<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Sabeltann.Views.CategoryGrid"
             x:Name="ThisControl">
    <Grid Background="#11111b" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*" Margin="16,8">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Width="28" Height="28" Padding="0" Margin="0,0,8,0"
                        Command="{Binding GoBackToPickerCommand}">
                    <TextBlock Text="←" Foreground="#cdd6f4" FontSize="18"/>
                </Button>
                <TextBlock Grid.Column="1" Text="Movies &amp; Shows"
                           Foreground="#cdd6f4" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Categories.Count, StringFormat='{}{0} categories loaded'}"
                               Foreground="#f38ba8" FontSize="14"/>
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding Name}" Foreground="#a6adc8" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Channels.Count, StringFormat='{}{0} channels'}"
                                               Foreground="#6c7086" FontSize="11"/>
                                    <ItemsControl ItemsSource="{Binding Channels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="140" Height="90" Margin="3"
                                                        Background="#181825" CornerRadius="8"
                                                        BorderThickness="1" BorderBrush="#313244">
                                                    <TextBlock Text="{Binding Name}" Foreground="#cdd6f4"
                                                               FontSize="11" TextTrimming="CharacterEllipsis"
                                                               Margin="8" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
