<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sabeltann.ViewModels"
             x:Name="Root"
             x:Class="Sabeltann.Views.SeriesBrowser">
    <!-- Filters (category / search / count) live in the app's morphing toolbar. -->
    <Grid Background="{StaticResource Bg}" RowDefinitions="*,Auto">

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <!-- Shows grid -->
                <WrapPanel IsVisible="{Binding ShowShows}" Margin="16,12">
                    <ItemsControl ItemsSource="{Binding Shows}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SeriesShowViewModel}">
                                <Button Background="{StaticResource Surface}" BorderThickness="1" BorderBrush="{StaticResource Line}"
                                        CornerRadius="12" Padding="0" Margin="6,6" Width="180"
                                        EffectiveViewportChanged="OnCoverViewport"
                                        Command="{Binding #Root.DataContext.SelectShowCommand}"
                                        CommandParameter="{Binding .}">
                                    <StackPanel>
                                        <Border Height="160" Background="{StaticResource Surface2}" CornerRadius="12,12,0,0">
                                            <Grid RowDefinitions="*,Auto">
                                                <Grid Grid.Row="0">
                                                    <Image Source="{Binding CoverSrc}" Stretch="UniformToFill"
                                                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                                    <TextBlock Text="{Binding Initial}"
                                                               Foreground="{StaticResource Muted}" FontSize="42" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               IsVisible="{Binding CoverSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                                </Grid>
                                                <Border Grid.Row="1" Background="{StaticResource Surface2}" Padding="6,3"
                                                        CornerRadius="0,0,12,12">
                                                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource Sub}" FontSize="10"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="13"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                   Margin="10,8"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>

                <!-- Episodes view -->
                <StackPanel IsVisible="{Binding ShowEpisodes}" Margin="16,12" Spacing="16">
                    <Button Background="Transparent" BorderThickness="0" Padding="8,4"
                            Command="{Binding BackToShowsCommand}"
                            HorizontalAlignment="Left">
                        <TextBlock Text="← Back to shows" Foreground="{StaticResource Info}" FontSize="13"/>
                    </Button>

                    <ItemsControl ItemsSource="{Binding SeasonGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SeasonGroup}">
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="{Binding Header}" Foreground="{StaticResource Accent}" FontSize="15"
                                               FontWeight="Bold" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Episodes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:VodEpisodeViewModel}">
                                                <Button Background="{StaticResource Surface}" BorderThickness="1" BorderBrush="{StaticResource Line}"
                                                        CornerRadius="9" Padding="12,10" Margin="0,3"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding #Root.DataContext.SelectEpisodeCommand}"
                                                        CommandParameter="{Binding .}">
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <Border Width="34" Height="34" CornerRadius="8"
                                                                Background="{StaticResource Surface2}">
                                                            <Grid>
                                                                <Image Source="{Binding PosterSrc}" Stretch="UniformToFill"
                                                                       Width="34" Height="34"/>
                                                                <TextBlock Text="▶" Foreground="{StaticResource Accent}" FontSize="10"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           IsVisible="{Binding PosterSrc, Converter={x:Static vm:MainViewModel.ImgFallback}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Display}"
                                                                   Foreground="{StaticResource Text}" FontSize="12.5"
                                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="0" IsVisible="{Binding IsLoading}" Background="#CC14161B"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Text}" FontSize="14"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" MinWidth="200" Height="4"
                             Foreground="{StaticResource Accent}" Background="{StaticResource Line}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="Press Escape to go back" Foreground="{StaticResource Muted}" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,8"/>
    </Grid>
</UserControl>
