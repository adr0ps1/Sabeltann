<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Sabeltann.Views.ContentPicker">
    <UserControl.Styles>
        <Style Selector="Button.ContentPickerCard">
            <Setter Property="RenderTransform" Value="{x:Null}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Style Selector="^:pointerover">
                <Setter Property="RenderTransform" Value="{x:Null}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource Surface2}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            </Style>
        </Style>
    </UserControl.Styles>
    <Grid Background="{StaticResource Bg}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Margin="60,40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

            <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center" Margin="0,0,0,32">
                <TextBlock Text="Select category"
                           Foreground="{StaticResource TextStrong}" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="*,24,*,24,*" HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Button x:Name="LiveTvBtn" Grid.Column="0" Classes="ContentPickerCard"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource Surface2}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="▦" Foreground="{StaticResource Accent}" FontSize="34" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Live TV" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Watch live channels and streams"
                                       Foreground="{StaticResource Muted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button x:Name="MoviesBtn" Grid.Column="2" Classes="ContentPickerCard"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource Surface2}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="▷" Foreground="{StaticResource Accent}" FontSize="34" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Movies" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Browse movies and films"
                                       Foreground="{StaticResource Muted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button x:Name="SeriesBtn" Grid.Column="4" Classes="ContentPickerCard"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource Surface2}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="⊞" Foreground="{StaticResource Accent}" FontSize="34" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Series" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Browse TV shows and episodes"
                                       Foreground="{StaticResource Muted}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Grid>

            <TextBlock Grid.Row="2" Text="Press Escape to go back"
                       Foreground="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center" Margin="0,24,0,0"/>
        </Grid>
        </Border>
    </Grid>
</UserControl>
